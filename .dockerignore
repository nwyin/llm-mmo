# Build context is the repo root (see bot/Dockerfile). The image keeps the FULL repo because
# the bot reads knowledge/, personas/, .agents/skills/ at runtime AND needs .git for the
# background knowledge pull. So .git/ and .agents/ are intentionally NOT excluded here.

# Not used by the bot at runtime (only by GitHub Actions / local tooling).
.github/
.claude/

# Secrets — never bake these into an image layer.
**/.env
.env
**/*.secrets.env
*.secrets.env

# Mutable runtime state — belongs on the volume, never in the image.
bot/.state/

# Python / tooling caches and virtualenvs
**/__pycache__/
**/*.pyc
**/.venv/
.venv/
.ruff_cache/
.pytest_cache/

# Agent run scratch
workflows/.work/
workflows/.upload/

# OS
.DS_Store
