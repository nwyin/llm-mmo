# --- Discord ---
DISCORD_BOT_TOKEN=                 # Bot tab → Token
DISCORD_GUILD_ID=                  # optional: your server id (instant slash-command sync)

# --- LLM (chat replies) ---
OPENROUTER_API_KEY=sk-or-...       # https://openrouter.ai

# --- GitHub (dispatching actions) ---
GITHUB_DISPATCH_TOKEN=             # fine-grained PAT with Actions: write on your fork
GITHUB_REPO=youruser/yourfork      # owner/repo to dispatch actions to

# --- Admins (privileged tools) ---
# Set [admins].ids in config.toml to your Discord user id(s) to enable cron, workspace_recall,
# interactive skill_manage, and user-profile memory. Empty = those tools are off for everyone.

# --- Web research ---
# Recommended provider is Exa (neural search, good for research/competitor/client discovery).
# It's the default in config.toml; set the key below. Without a key the bot falls back to
# keyless DuckDuckGo, so this is optional but strongly recommended for real use.
EXA_API_KEY=                       # https://exa.ai
# Alternatives:
# WEB_SEARCH_PROVIDER=tavily       # or "ddgs" (keyless)
# TAVILY_API_KEY=                  # https://tavily.com  (if provider=tavily)
