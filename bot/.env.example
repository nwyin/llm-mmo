# --- Discord ---
DISCORD_BOT_TOKEN=                 # Bot tab → Token
DISCORD_GUILD_ID=                  # optional: your server id (instant slash-command sync)

# --- LLM (chat replies) ---
OPENROUTER_API_KEY=sk-or-...       # https://openrouter.ai

# --- GitHub (dispatching actions) ---
GITHUB_DISPATCH_TOKEN=             # fine-grained PAT with Actions: write on your fork
GITHUB_REPO=youruser/yourfork      # owner/repo to dispatch actions to
